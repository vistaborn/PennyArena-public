# Circle Modular Wallets — Client Key (Console → Keys → Client Key → Web → localhost)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=TEST_API_KEY:your-client-key
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl

# Circle entity — API Key + run: npm run register-entity
CIRCLE_API_KEY=TEST_API_KEY:your-api-key

# Treasury wallet receives publish / duel / vote fees (your Arc testnet address)
NEXT_PUBLIC_PENNY_TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# Private key for the treasury wallet — required for on-chain claim payouts
PENNY_TREASURY_PRIVATE_KEY=0xYourTreasuryPrivateKey64HexChars

# Session cookie signing (min 32 chars in production)
PENNY_SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional: protect cron-style endpoints (duel settlement)
CRON_SECRET=

# Optional: protect admin seed route in development
ADMIN_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: shared post storage on Vercel (Upstash Redis / Vercel KV integration)
# Vercel KV adds KV_REST_API_URL + KV_REST_API_TOKEN automatically.
# Manual Upstash setup uses UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
